rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasStoredRole(role) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function hasStoredAnyRole(roles) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        hasStoredRole('admin')
      );
    }

    function hasRole(role) {
      return isAuthenticated() && (
        request.auth.token.role == role ||
        hasStoredRole(role)
      );
    }

    function hasAnyRole(roles) {
      return isAuthenticated() && (
        request.auth.token.role in roles ||
        hasStoredAnyRole(roles)
      );
    }

    function authRole() {
      return isAuthenticated() && request.auth.token.admin == true
        ? 'admin'
        : (
          isAuthenticated() && request.auth.token.role is string
            ? request.auth.token.role
            : null
        );
    }

    function authEmail() {
      return isAuthenticated() && request.auth.token.email is string
        ? request.auth.token.email
        : null;
    }

    function authEmailVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    function validUserStatus(status) {
      return status in ['active', 'inactive', 'suspended'];
    }

    function canCreateOwnUserProfile(userId) {
      return isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.data.uid == request.auth.uid &&
        authRole() != null &&
        request.resource.data.role == authRole() &&
        (
          authEmail() == null ||
          request.resource.data.email == authEmail()
        ) &&
        request.resource.data.keys().hasAll(['status']) &&
        validUserStatus(request.resource.data.status) &&
        (
          !request.resource.data.keys().hasAny(['emailVerified']) ||
          request.resource.data.emailVerified == authEmailVerified()
        );
    }

    function canUpdateOwnUserProfile(userId) {
      return isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.uid == request.auth.uid &&
        (
          authRole() != null
            ? request.resource.data.role == authRole()
            : (
              resource.data.keys().hasAny(['role']) &&
              request.resource.data.role == resource.data.role
            )
        ) &&
        (
          authEmail() == null
            ? (
              !resource.data.keys().hasAny(['email']) ||
              request.resource.data.email == resource.data.email
            )
            : request.resource.data.email == authEmail()
        ) &&
        (
          !resource.data.keys().hasAny(['status']) ||
          request.resource.data.status == resource.data.status
        ) &&
        (
          !request.resource.data.keys().hasAny(['emailVerified']) ||
          request.resource.data.emailVerified == authEmailVerified()
        );
    }

    function currentUserTeamId() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId is string
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId
        : null;
    }

    function dataHasTeamId(data) {
      return data.keys().hasAny(['teamId']) &&
        data.teamId is string &&
        data.teamId.size() > 0;
    }

    function resourceMatchesTeam() {
      return !dataHasTeamId(resource.data) ||
        currentUserTeamId() == null ||
        (currentUserTeamId() != null && resource.data.teamId == currentUserTeamId());
    }

    function requestMatchesTeam() {
      return dataHasTeamId(request.resource.data) &&
        (currentUserTeamId() == null || request.resource.data.teamId == currentUserTeamId());
    }

    function requestMatchesExistingOrLegacy() {
      return (
        !dataHasTeamId(resource.data) &&
        (
          !request.resource.data.keys().hasAny(['teamId']) ||
          requestMatchesTeam()
        )
      ) || (
        dataHasTeamId(resource.data) &&
        requestMatchesTeam() &&
        request.resource.data.teamId == resource.data.teamId
      );
    }

    function legacyOrScopedCreate() {
      return !request.resource.data.keys().hasAny(['teamId']) ||
        currentUserTeamId() == null ||
        requestMatchesTeam();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        (
          hasAnyRole(['manager', 'statistician', 'coach', 'media']) &&
          resourceMatchesTeam()
        ) ||
        request.auth.uid == userId
      );
      allow create: if isAdmin() || canCreateOwnUserProfile(userId);
      allow delete: if isAdmin();
      allow update: if isAdmin() || canUpdateOwnUserProfile(userId);
    }

    match /teams/{teamId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        teamId == currentUserTeamId() ||
        resource.data.createdBy == request.auth.uid ||
        hasAnyRole(['coach', 'media', 'manager', 'statistician'])
      );
      allow create: if isAuthenticated() &&
        hasAnyRole(['admin', 'manager', 'coach', 'statistician', 'media']);
      allow update: if isAuthenticated() && (
        isAdmin() ||
        resource.data.createdBy == request.auth.uid ||
        teamId == currentUserTeamId() ||
        hasAnyRole(['coach', 'media', 'manager', 'statistician'])
      );
      allow delete: if isAdmin();
    }

    match /athletes/{athleteId} {
      allow read: if true;
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach', 'media']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && resourceMatchesTeam();
    }

    match /blogPosts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'media', 'manager']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'media', 'manager']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'media', 'manager']) && resourceMatchesTeam();
    }

    match /programs/{programId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']);

      match /enrollments/{enrollmentId} {
        allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']);
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && hasAnyRole(['admin', 'manager']);
      }

      match /completions/{completionId} {
        allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']);
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && hasAnyRole(['admin', 'manager']);
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && resourceMatchesTeam();
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach', 'statistician']);
      allow create, update, delete: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']);
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /contacts/{contactId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager']);
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /enquiries/{enquiryId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager']);
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow create: if isAuthenticated() &&
        hasAnyRole(['admin', 'manager', 'media', 'statistician', 'coach']) &&
        legacyOrScopedCreate();

      allow read: if isAuthenticated() && (
        isAdmin() ||
        (
          resourceMatchesTeam() &&
          (
            resource.data.userId == request.auth.uid ||
            (hasRole('manager') && resource.data.recipientRole in ['manager', 'admin', 'all']) ||
            (hasRole('media') && resource.data.recipientRole in ['media', 'admin', 'all']) ||
            (hasRole('statistician') && resource.data.recipientRole in ['statistician', 'admin', 'all']) ||
            (hasRole('coach') && resource.data.recipientRole in ['coach', 'admin', 'all'])
          )
        )
      );

      allow update: if isAdmin() || (
        isAuthenticated() &&
        resourceMatchesTeam() &&
        resource.data.userId == request.auth.uid &&
        // Only the read field may be changed by the notification owner.
        // All identity / content fields must remain immutable.
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.recipientRole == resource.data.recipientRole &&
        request.resource.data.type == resource.data.type &&
        request.resource.data.createdAt == resource.data.createdAt
      );

      allow delete: if isAdmin() || (
        isAuthenticated() &&
        resourceMatchesTeam() &&
        resource.data.userId == request.auth.uid
      );
    }

    match /certificates/{certificateId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']);
    }

    match /bsmMedia/{mediaId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media', 'coach']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'media']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'media']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'media']) && resourceMatchesTeam();
    }

    match /bsm_media/{mediaId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media', 'coach']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'media']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'media']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'media']) && resourceMatchesTeam();
    }

    match /trainingSessions/{sessionId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager']) && resourceMatchesTeam();
    }

    match /attendance/{recordId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager']) && resourceMatchesTeam();
    }

    match /players/{playerId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach', 'media']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager']) && resourceMatchesTeam();
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach', 'media']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager']) && resourceMatchesTeam();
    }

    match /matchEvents/{eventId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager']) && resourceMatchesTeam();
    }

    match /performance/{recordId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'statistician', 'coach']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager']) && resourceMatchesTeam();
    }

    match /matchSquads/{squadId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager']) && resourceMatchesTeam();
    }

    match /formations/{formationId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager']) && resourceMatchesTeam();
    }

    match /trainingPlans/{planId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager']) && resourceMatchesTeam();
    }

    match /playerStatuses/{statusId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager']) && resourceMatchesTeam();
    }

    match /matchPreparations/{prepId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'coach']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager']) && resourceMatchesTeam();
    }

    match /posts/{postId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && resourceMatchesTeam();
    }

    match /media/{mediaId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media', 'coach']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && resourceMatchesTeam();
    }

    match /announcements/{announcementId} {
      allow read: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && resourceMatchesTeam();
      allow create: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && legacyOrScopedCreate();
      allow update: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && requestMatchesExistingOrLegacy();
      allow delete: if isAuthenticated() && hasAnyRole(['admin', 'manager', 'media']) && resourceMatchesTeam();
    }
  }
}
